# Copy this file to .env. For local dev without Postgres, leave DATABASE_URL empty (uses SQLite).

# Database (optional for local: empty = SQLite file in backend folder)
# DATABASE_URL=postgresql://user:pass@localhost:5432/residence_amizade

# PayDunya: set for payments. Production = no customer login on checkout.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
# test = sandbox (payer may need test account); production = real payments, no login
PAYDUNYA_MODE=test

# Next.js base URL (for return URL after payment)
FRONTEND_URL=http://localhost:3000

# IPN: PayDunya POSTs here when payment completes. Backend runs on port 8001.
# Set PayDunya dashboard IPN endpoint to this SAME URL (e.g. https://xxx.ngrok.io/paydunya/webhook).
# Local: run "ngrok http 8001", then set PAYDUNYA_CALLBACK_URL to https://YOUR_NGROK_URL/paydunya/webhook
PAYDUNYA_CALLBACK_URL=

# Confirmation email (Resend). Required for real delivery.
# Get API key at https://resend.com
# RESEND_API_KEY=re_xxxx
# Optional: from address (default: onboarding@resend.dev for testing)
# RESEND_FROM=Residence Amizade <booking@yourdomain.com>
# Optional: link in email
# CANCELLATION_POLICY_URL=https://yoursite.com/conditions-generales

# Optional: secret for recording offline/WhatsApp bookings (POST /api/bookings/manual).
# Set a long random string; send it in header: X-Admin-Secret: your-secret
# ADMIN_SECRET=your-long-random-secret
