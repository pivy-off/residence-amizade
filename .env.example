# Wave payment (Wave Money) – get your API key from https://business.wave.com/dev-portal
# Leave empty to hide the "Pay with Wave" option (guests can still book via WhatsApp/call).
WAVE_API_KEY=

# PayDunya backend (FastAPI) – used for Pay with Wave/Orange/Free/Card via PayDunya.
# Local: http://localhost:8000  (run backend with: cd backend && uvicorn main:app --port 8000)
# Production: https://your-backend-domain.com
# If set, booking flow will use PayDunya create; if unset, falls back to Wave-only when WAVE_API_KEY is set.
BACKEND_URL=
# PAYDUNYA_BACKEND_URL=  # alternative env name

# Optional: base URL for Wave success/error redirects (e.g. https://yoursite.com).
# If unset, the app uses the current origin (works for same-domain deployment).
# NEXT_PUBLIC_APP_URL=https://residenceamizade.vercel.app
